# PostgreSQL credentials (used by both the db and importer services)
POSTGRES_USER=optcg
POSTGRES_PASSWORD=change_me
POSTGRES_DB=optcg
POSTGRES_PORT=5432

# Image hosting
# Local: http://localhost:8081 (or your static file server)
# AWS: your CloudFront domain (e.g. https://d123.cloudfront.net)
IMAGE_BASE_URL=http://localhost:8081

# Optional pgAdmin (only started with the "tools" profile)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080
